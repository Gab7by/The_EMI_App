{
  "expo": {
    "name": "The Menorah",
    "slug": "The_EMI_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/emi-app-icon.png",
    "scheme": "themenorah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bitcode": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "The Menorah needs microphone access for live audio sessions",
        "NSPhotoLibraryUsageDescription": "The Menorah needs access to your photos",
        "NSCameraUsageDescription": "The Menorah needs camera access",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0B1F0E",
        "foregroundImage": "./assets/images/emi-app-icon.png",
        "backgroundImage": "./assets/images/emi-app-icon.png",
        "monochromeImage": "./assets/images/emi-app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.snrroko.the_menorah"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-light.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#0B1F0E"
        }
      ],
      "expo-secure-store",
      "./plugins/with-foreground-service",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      [
        "expo-image-picker",
        {
          "photosPermission": "The Menorah needs access to your photos to set your profile picture and session backgrounds",
          "cameraPermission": "The Menorah needs camera access to take your profile picture"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b1d09bd-22b8-466c-89d6-02223ca1e415"
      }
    },
    "owner": "snrroko"
  }
}
